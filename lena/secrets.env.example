# Secrets injected into LiveKit Cloud agent runtime
# Usage:
#   cp secrets.env.example secrets.env
#   # fill values
#   lk agent create --region eu-central --secrets-file secrets.env .

XAI_API_KEY=your_xai_api_key
TELNYX_API_KEY=your_telnyx_api_key

# Optional runtime tuning (not secret, but convenient to keep here)
LENA_XAI_MODEL=grok-voice-fast-1.0
LENA_XAI_VOICE=Ara
XAI_MODEL=grok-voice-fast-1.0
XAI_VOICE=ara

# Sidecar orchestration (LangGraph, no extra voice latency)
ENABLE_LANGGRAPH_ORCHESTRATOR=true
ENABLE_TOOL_CALLING=true
ENABLE_WEB_SEARCH=false
ENABLE_X_SEARCH=false
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8000

# Turn detection tuning (telephony defaults are set in code)
LENA_TURN_DETECTION_TYPE=server_vad
LENA_TURN_THRESHOLD=0.5
LENA_TURN_PREFIX_PADDING_MS=160
LENA_TURN_SILENCE_DURATION_MS=520
LENA_TURN_INTERRUPT_RESPONSE=true
LENA_TURN_CREATE_RESPONSE=true
LENA_TURN_EAGERNESS=medium

# Prompt branding (optional)
LENA_COMPANY_NAME=step2job Berlin
LENA_OFFER_NAME=Stellenanzeigen-/Recruiting-Ads auf Jobportalen
LENA_TARGET_CUSTOMERS=HR- und Recruiting-Verantwortliche

# LiveKit SIP IDs (optional, but useful for ops)
SIP_OUTBOUND_TRUNK_ID=ST_...
SIP_INBOUND_TRUNK_ID=ST_...

# Telnyx resource IDs (optional, but useful for ops)
TELNYX_FQDN_CONNECTION_ID=...
TELNYX_FQDN_ID=...
TELNYX_OUTBOUND_VOICE_PROFILE_ID=...
TELNYX_PHONE_NUMBER_ID=...
TELNYX_PHONE_NUMBER=+49...

# LiveKit SIP endpoint (for docs/ops)
LIVEKIT_SIP_FQDN=xxxx.sip.livekit.cloud
